+- (int)resetCompressionSessionForRuntimeMaxQpIfNeeded:(BOOL *)didReset {
+  RTC_DCHECK(didReset);
+  *didReset = NO;
+  NSDictionary<NSString *, id> *(^provider)(void) =
+      _castTuningOptions[@"encoder_runtime_qp_provider"];
+  if (!provider || _lastAppliedMaxQpGeneration == 0) {
+    return WEBRTC_VIDEO_CODEC_OK;
+  }
+  NSNumber *generation = provider()[@"generation"];
+  if (![generation isKindOfClass:[NSNumber class]] ||
+      generation.unsignedLongLongValue == _lastAppliedMaxQpGeneration) {
+    return WEBRTC_VIDEO_CODEC_OK;
+  }
+  const int status = [self resetCompressionSession];
+  if (status == WEBRTC_VIDEO_CODEC_OK) {
+    *didReset = YES;
+  }
+  return status;
+}
+
+- (NSDictionary<NSString *, id> *)applyPendingCastTuningMaxQp {
+  NSDictionary<NSString *, id> *(^provider)(void) =
+      _castTuningOptions[@"encoder_runtime_qp_provider"];
+  if (!provider || !_compressionSession) {
+    return @{};
+  }
+
+  NSDictionary<NSString *, id> *request = provider();
+  NSNumber *generation = request[@"generation"];
+  NSNumber *requestedMaxQp = request[@"requested_max_qp"];
+  if (![generation isKindOfClass:[NSNumber class]] ||
+      ![requestedMaxQp isKindOfClass:[NSNumber class]] ||
+      generation.unsignedLongLongValue == _lastAppliedMaxQpGeneration) {
+    return request ?: @{};
+  }
+
+  NSString *eventType = @"encoder_runtime_qp_failed";
+  OSStatus status = kVTPropertyNotSupportedErr;
+  NSNumber *effectiveMaxQp = nil;
+  if (@available(macOS 12.0, iOS 15.0, *)) {
+    CFDictionaryRef supportedProperties = nullptr;
+    status = VTSessionCopySupportedPropertyDictionary(_compressionSession,
+                                                       &supportedProperties);
+    NSDictionary *propertyInfo = nil;
+    if (status == noErr && supportedProperties) {
+      propertyInfo = [(__bridge NSDictionary *)supportedProperties
+          objectForKey:(__bridge NSString *)
+                           kVTCompressionPropertyKey_MaxAllowedFrameQP];
+    }
+    NSString *readWriteStatus = propertyInfo[
+        (__bridge NSString *)kVTPropertyReadWriteStatusKey];
+    const BOOL supported = propertyInfo &&
+        [readWriteStatus
+            isEqualToString:(__bridge NSString *)
+                                kVTPropertyReadWriteStatus_ReadWrite];
+    if (supportedProperties) {
+      CFRelease(supportedProperties);
+    }
+    if (!supported) {
+      eventType = @"encoder_runtime_qp_unsupported";
+      status = kVTPropertyNotSupportedErr;
+    } else {
+      status = VTSessionSetProperty(
+          _compressionSession,
+          kVTCompressionPropertyKey_MaxAllowedFrameQP,
+          (__bridge CFNumberRef)requestedMaxQp);
+      if (status == noErr) {
+        CFTypeRef copiedValue = nullptr;
+        status = VTSessionCopyProperty(
+            _compressionSession,
+            kVTCompressionPropertyKey_MaxAllowedFrameQP,
+            nullptr,
+            &copiedValue);
+        if (status == noErr && copiedValue &&
+            CFGetTypeID(copiedValue) == CFNumberGetTypeID()) {
+          effectiveMaxQp = [(__bridge NSNumber *)copiedValue copy];
+          eventType = @"encoder_runtime_qp_applied";
+        } else if (status == noErr) {
+          status = kVTPropertyNotSupportedErr;
+        }
+        if (copiedValue) {
+          CFRelease(copiedValue);
+        }
+      }
+    }
+  } else {
+    eventType = @"encoder_runtime_qp_unsupported";
+  }
+
+  _lastAppliedMaxQpGeneration = generation.unsignedLongLongValue;
+  NSMutableDictionary<NSString *, id> *event = [@{
+    @"event_type" : eventType,
+    @"requested_max_qp" : requestedMaxQp,
+    @"generation" : generation,
+    @"os_status" : @(status),
+    @"encoder_id" : _encoderId ?: @"UNKNOWN",
+    @"encoder_session_id" : _encoderSessionId ?: @"UNKNOWN",
+  } mutableCopy];
+  event[@"codec_name"] = @"H265";
+  if (effectiveMaxQp) {
+    event[@"effective_max_qp"] = effectiveMaxQp;
+  }
+  void (^resultHandler)(NSDictionary<NSString *, id> *) =
+      _castTuningOptions[@"encoder_runtime_qp_result_handler"];
+  if (resultHandler) {
+    resultHandler(event);
+  }
+  return request;
+}
