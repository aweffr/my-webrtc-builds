+struct CastRecoverySettings {
+  bool configured = false;
+  bool nack = true;
+  int nack_history_ms = kNackHistoryMs;
+  bool rtx = true;
+  std::string fec = "upstream";
+  int pli_min_interval_ms = 0;
+};
+
+CastRecoverySettings GetCastRecoverySettings(const FieldTrialsView& trials) {
+  CastRecoverySettings settings;
+  const std::string trial(
+      trials.Lookup("WebRTC-CastTuning-Recovery"));
+  if (trial.empty()) {
+    return settings;
+  }
+  settings.configured = true;
+  FieldTrialParameter<bool> nack("nack", true);
+  FieldTrialParameter<int> nack_history_ms("nack_history_ms", kNackHistoryMs);
+  FieldTrialParameter<bool> rtx("rtx", true);
+  FieldTrialParameter<std::string> fec("fec", "disabled");
+  FieldTrialParameter<int> pli_min_interval_ms("pli_min_interval_ms", 500);
+  ParseFieldTrial(
+      {&nack, &nack_history_ms, &rtx, &fec, &pli_min_interval_ms}, trial);
+  settings.nack = nack.Get();
+  settings.nack_history_ms =
+      std::clamp(nack_history_ms.Get(), 0, 5000);
+  settings.rtx = rtx.Get();
+  settings.fec = fec.Get();
+  settings.pli_min_interval_ms =
+      std::clamp(pli_min_interval_ms.Get(), 100, 5000);
+  return settings;
+}
+
 // Minimum time interval for logging stats.
